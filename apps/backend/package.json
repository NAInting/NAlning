  },
  "dependencies": {
    "@edu-ai/shared-types": "workspace:*",
    "@hono/node-server": "^1.19.6",
    "hono": "^4.10.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
